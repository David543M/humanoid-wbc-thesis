\@writefile{lof}{\contentsline {figure}{\numberline {2.4}{\ignorespaces Qualitative comparison of Whole-Body Control approaches across six evaluation dimensions. \text  {$\mathsurround \z@ \mathchar "458$}~=~satisfied / low cost / supported; $\sim $~=~partial; $\times $~=~not satisfied / high cost / absent. The proposed framework (last row, highlighted) scores favourably on constraint satisfaction, multi-contact support, loco-manipulation, and evaluation protocol — dimensions where existing approaches show the clearest limitations. Scores are grounded in the literature surveyed in Sections \ref {sec:sota_nullspace}--\ref {sec:sota_sim}.}}{13}{figure.caption.9}\protected@file@percent }
\newlabel{fig:wbc_comparison}{{2.4}{13}{Qualitative comparison of Whole-Body Control approaches across six evaluation dimensions. \checkmark ~=~satisfied / low cost / supported; $\sim $~=~partial; $\times $~=~not satisfied / high cost / absent. The proposed framework (last row, highlighted) scores favourably on constraint satisfaction, multi-contact support, loco-manipulation, and evaluation protocol — dimensions where existing approaches show the clearest limitations. Scores are grounded in the literature surveyed in Sections \ref {sec:sota_nullspace}--\ref {sec:sota_sim}}{figure.caption.9}{}}
\newlabel{fig:wbc_comparison@cref}{{[figure][4][2]2.4}{[1][13][]13}{}{}{}}
