\@writefile{lof}{\contentsline {figure}{\numberline {2.3}{\ignorespaces Hierarchical planning/execution architecture for model-based humanoid Whole-Body Control. The centroidal MPC layer generates wrench references and a contact schedule at 50--100\,Hz; the QP-based WBC layer distributes these to joint torques at 1\,kHz. The coupling interface (orange) is the underdocumented boundary identified as a methodological gap in the literature and constitutes a primary contribution of this thesis.}}{9}{figure.caption.8}\protected@file@percent }
\newlabel{fig:wbc_architecture}{{2.3}{9}{Hierarchical planning/execution architecture for model-based humanoid Whole-Body Control. The centroidal MPC layer generates wrench references and a contact schedule at 50--100\,Hz; the QP-based WBC layer distributes these to joint torques at 1\,kHz. The coupling interface (orange) is the underdocumented boundary identified as a methodological gap in the literature and constitutes a primary contribution of this thesis}{figure.caption.8}{}}
\newlabel{fig:wbc_architecture@cref}{{[figure][3][2]2.3}{[1][9][]9}{}{}{}}
